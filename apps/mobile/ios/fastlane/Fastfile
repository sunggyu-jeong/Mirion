default_platform(:ios)

DEV_BUNDLE_ID  = "org.teammoodlyWhaleTracker.dev"
PROD_BUNDLE_ID = "org.teammoodlyWhaleTracker"

platform :ios do
  desc "Run JS unit tests with coverage"
  lane :test do
    Dir.chdir("../../..") do
      sh("pnpm --filter @whaletracker/mobile test --ci --coverage")
    end
  end

  desc "Build for simulator (no code signing)"
  lane :build_dev do
    xcodebuild(
      workspace: "WhaleTracker.xcworkspace",
      scheme: "WhaleTracker",
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      derived_data_path: "build",
      xcargs: "CODE_SIGNING_ALLOWED=NO",
      buildlog_path: "build/Logs"
    )
  end

  desc "[개발] Debug 빌드 → TestFlight (dev 번들 ID: #{DEV_BUNDLE_ID})"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )

    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: DEV_BUNDLE_ID
      ) + 1,
      xcodeproj: "WhaleTracker.xcodeproj"
    )

    build_app(
      workspace: "WhaleTracker.xcworkspace",
      scheme: "WhaleTracker",
      configuration: "Debug",
      export_method: "app-store",
      api_key: api_key
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: DEV_BUNDLE_ID,
      skip_waiting_for_build_processing: true
    )
  end

  desc "[운영] Release 빌드 → App Store (prod 번들 ID: #{PROD_BUNDLE_ID})"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )

    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: PROD_BUNDLE_ID
      ) + 1,
      xcodeproj: "WhaleTracker.xcodeproj"
    )

    build_app(
      workspace: "WhaleTracker.xcworkspace",
      scheme: "WhaleTracker",
      configuration: "Release",
      export_method: "app-store",
      api_key: api_key
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: PROD_BUNDLE_ID,
      submit_for_review: false,
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: true
    )
  end
end
